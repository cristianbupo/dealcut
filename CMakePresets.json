{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "mpi-release",
      "displayName": "MPI Release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "mpicc",
        "CMAKE_CXX_COMPILER": "mpicxx"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "square_dealii",
      "displayName": "Build square_dealii",
      "configurePreset": "mpi-release",
      "targets": ["square_dealii"]
    },
    {
      "name": "square_cutlib",
      "displayName": "Build square_cutlib",
      "configurePreset": "mpi-release",
      "targets": ["square_cutlib"]
    },
    {
      "name": "square_both",
      "displayName": "Build square_dealii + square_cutlib",
      "configurePreset": "mpi-release",
      "targets": ["square_dealii", "square_cutlib"]
    }
  ]
}
